{
  "name": "agestra",
  "version": "4.2.1",
  "description": "Claude Code plugin — orchestrate Ollama, Gemini, and Codex for multi-AI debates, cross-validation, and GraphRAG memory",
  "type": "module",
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "packages/*"
  ],
  "main": "dist/bundle.js",
  "bin": {
    "agestra": "dist/bundle.js"
  },
  "files": [
    "dist/bundle.js",
    "dist/sql-wasm.js",
    "dist/sql-wasm.wasm",
    ".claude-plugin/",
    "agents/",
    "commands/",
    "hooks/",
    "skills/"
  ],
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "bundle": "node scripts/bundle.mjs",
    "prepublishOnly": "npm run build && npm run bundle"
  },
  "keywords": [
    "claude-code-plugin",
    "mcp",
    "multi-ai",
    "ollama",
    "gemini",
    "codex",
    "ai-orchestration"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mua-vtuber/Agestra.git"
  },
  "homepage": "https://github.com/mua-vtuber/Agestra",
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.2",
    "turbo": "^2.8.12",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.54.0",
    "vitest": "^2.1.9"
  }
}
